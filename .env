# EchoMind 环境变量
# docker compose 部署时会自动读取此文件

# ── Anthropic / DeepSeek ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-2a4ec3dee4dd4c8e81fb965809e9e1f3
ANTHROPIC_MODEL=deepseek-chat
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# ── 应用 ──────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=echomind123
# docker compose 内部地址（容器间通信）
REDIS_URL=redis://:echomind123@redis:6379/0

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# docker compose 内部地址
CHROMA_PERSIST_DIRECTORY=/app/data/chroma

# ── 监控 ──────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
MONITOR_INTERVAL=10
ALERT_WEBHOOK_URL=
